<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <PackageId>Stella.Ergosfare.SourceGenerator</PackageId>
        <IsPackable>true</IsPackable>

        <!-- Analyzers load inside the compiler process (VS/Rider/CLI), which may run on
             .NET Framework — netstandard2.0 is the required target for generators.
             Single-target (clearing the inherited TargetFrameworks) so pack sees the
             TFM-qualified output path. -->
        <TargetFrameworks></TargetFrameworks>
        <TargetFramework>netstandard2.0</TargetFramework>
        <IsAotCompatible>false</IsAotCompatible>
        <IsRoslynComponent>true</IsRoslynComponent>
        <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>

        <!-- Generator packages ship the assembly under analyzers/, never under lib/:
             consumers get compile-time codegen and no runtime dependency. -->
        <IncludeBuildOutput>false</IncludeBuildOutput>
        <DevelopmentDependency>true</DevelopmentDependency>
        <SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
        <NoWarn>$(NoWarn);NU5128</NoWarn>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.8.0" PrivateAssets="all" />
        <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" Version="3.3.4" PrivateAssets="all" />
    </ItemGroup>

    <ItemGroup>
        <AdditionalFiles Include="AnalyzerReleases.Shipped.md" />
        <AdditionalFiles Include="AnalyzerReleases.Unshipped.md" />
    </ItemGroup>

    <ItemGroup>
        <None Include="$(OutputPath)\$(AssemblyName).dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
    </ItemGroup>
</Project>
