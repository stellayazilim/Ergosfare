{
  "metadata": [
    {
      "src": [
        {
          "files": ["src/**/*.csproj"],
          "exclude": [
            "**/bin/**",
            "**/obj/**",
            "src/Stella.Ergosfare.SourceGenerator/**"
          ]
        }
      ],
      "dest": "api",
      "outputFormat": "mref",
      "namespaceLayout": "nested",
      "memberLayout": "samePage",
      "filter": "docfx.filter.yml",
      "properties": {
        "TargetFramework": "net10.0"
      }
    }
  ],
  "build": {
    "content": [
      { "files": ["api/**.yml", "api/index.md"] },
      { "files": ["articles/**.md"] },
      { "files": ["toc.yml", "*.md"] }
    ],
    "dest": "_site",
    "markdownEngineName": "markdig"
  }
}
